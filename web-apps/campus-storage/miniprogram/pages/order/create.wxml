<!--pages/order/create.wxml-->
<view class="container">
  <!-- 城市选择 -->
  <view class="card">
    <view class="card-title">选择城市</view>
    <view class="city-selector">
      <view
        class="city-item {{selectedCity === item ? 'active' : ''}}"
        wx:for="{{cities}}"
        wx:key="*this"
        bindtap="selectCity"
        data-city="{{item}}"
      >
        {{item}}
      </view>
    </view>
  </view>

  <!-- 物品类型 -->
  <view class="card">
    <view class="card-title">物品类型</view>
    <view class="type-selector">
      <view
        class="type-item {{selectedType === item.value ? 'active' : ''}}"
        wx:for="{{itemTypes}}"
        wx:key="value"
        bindtap="selectType"
        data-type="{{item.value}}"
      >
        <text class="type-icon">{{item.icon}}</text>
        <text class="type-name">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 仓库选择 -->
  <view class="card" wx:if="{{selectedCity}}">
    <view class="card-title">选择仓库</view>
    <!-- 加载中 -->
    <view class="loading-state" wx:if="{{warehouseLoading}}">
      <text class="loading-text">加载仓库中...</text>
    </view>
    <!-- 仓库列表 -->
    <view class="warehouse-list" wx:else>
      <view
        class="warehouse-item {{selectedWarehouse === item.id ? 'active' : ''}}"
        wx:for="{{warehouses}}"
        wx:key="id"
        bindtap="selectWarehouse"
        data-id="{{item.id}}"
      >
        <view class="warehouse-name">{{item.name}}</view>
        <view class="warehouse-address">{{item.address}}</view>
      </view>
      <!-- 无仓库时的提示 -->
      <view class="empty-hint" wx:if="{{warehouses.length === 0}}">
        <text>暂无可用仓库</text>
      </view>
    </view>
  </view>

  <!-- 费用预估 -->
  <view class="card fee-card" wx:if="{{selectedWarehouse}}">
    <view class="card-title">费用预估</view>
    <view class="fee-list">
      <view class="fee-item">
        <text class="fee-label">存储费</text>
        <text class="fee-value">¥{{fee.storage}}</text>
      </view>
      <view class="fee-item">
        <text class="fee-label">配送费</text>
        <text class="fee-value">¥{{fee.delivery}}</text>
      </view>
      <view class="fee-item">
        <text class="fee-label">保险费</text>
        <text class="fee-value">¥{{fee.insurance}}</text>
      </view>
      <view class="divider"></view>
      <view class="fee-item fee-total">
        <text class="fee-label">预估总计</text>
        <text class="fee-value">¥{{fee.total}}</text>
      </view>
    </view>
  </view>

  <!-- 底部提交按钮 -->
  <view class="footer-bar">
    <view class="fee-preview" wx:if="{{selectedWarehouse}}">
      <text class="fee-preview-label">预估:</text>
      <text class="fee-preview-value">¥{{fee.total}}</text>
    </view>
    <view
      class="btn btn-primary {{canSubmit ? '' : 'disabled'}}"
      bindtap="submitOrder"
    >
      {{submitting ? '提交中...' : (canSubmit ? '立即下单' : '请完善信息')}}
    </view>
  </view>
</view>
