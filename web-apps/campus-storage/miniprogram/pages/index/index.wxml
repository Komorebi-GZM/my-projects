<!--pages/index/index.wxml-->
<view class="container">
  <!-- Banner轮播区 -->
  <swiper wx:if="{{banners.length > 0}}" class="banner" indicator-dots autoplay circular interval="3000" duration="500">
    <swiper-item wx:for="{{banners}}" wx:key="id" bindtap="onBannerTap" data-item="{{item}}">
      <image class="banner-image" src="{{item.imageUrl}}" mode="aspectFill" />
      <view class="banner-mask">
        <text class="banner-title">{{item.title}}</text>
        <text class="banner-subtitle">{{item.subtitle}}</text>
      </view>
    </swiper-item>
  </swiper>

  <!-- 快捷操作区 -->
  <view class="quick-actions">
    <view class="action-card action-primary" bindtap="goToCreateOrder">
      <view class="action-icon">📦</view>
      <view class="action-text">
        <text class="action-title">寄存物品</text>
        <text class="action-desc">地址未定，物品先行</text>
      </view>
    </view>
    <view class="action-card action-secondary" bindtap="goToOrderList">
      <view class="action-icon">📋</view>
      <view class="action-text">
        <text class="action-title">我的订单</text>
        <text class="action-desc">查看全部订单</text>
      </view>
    </view>
  </view>

  <!-- 进行中订单区 -->
  <view class="section-header">
    <text class="section-title">进行中</text>
    <text class="section-more" bindtap="goToOrderList" wx:if="{{activeOrders.length > 0}}">查看全部 ></text>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" wx:if="{{activeOrders.length > 0}}">
    <view class="order-card" wx:for="{{activeOrders}}" wx:key="_id" bindtap="goToOrderDetail" data-id="{{item._id}}">
      <view class="order-header">
        <text class="order-no">订单号：{{item.orderNo}}</text>
        <view class="tag tag-{{item.statusStyle}}">{{item.statusText}}</view>
      </view>
      <view class="order-body">
        <view class="order-icon">{{item.itemIcon}}</view>
        <view class="order-info">
          <text class="order-type">{{item.itemTypeText}}</text>
          <text class="order-city">📍 {{item.city}}</text>
        </view>
      </view>
      <view class="order-footer">
        <text class="order-time">{{item.createTimeText}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{activeOrders.length === 0 && !loading}}">
    <view class="empty-icon">📭</view>
    <text class="empty-text">暂无进行中的订单</text>
    <view class="btn btn-primary" bindtap="goToCreateOrder">去寄存物品</view>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
