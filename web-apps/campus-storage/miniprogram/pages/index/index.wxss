/**pages/index/index.wxss**/

/* Banner样式 */
.banner {
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
}

.banner-title {
  display: block;
  font-size: 18px;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.banner-subtitle {
  display: block;
  font-size: 12px;
  color: rgba(255,255,255,0.8);
}

/* 快捷操作区 */
.quick-actions {
  display: flex;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.action-card {
  flex: 1;
  padding: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.action-primary {
  background: linear-gradient(135deg, #1890FF, #096DD9);
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.3);
}

.action-secondary {
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.action-icon {
  font-size: 48rpx;
}

.action-text {
  display: flex;
  flex-direction: column;
}

.action-title {
  font-size: 16px;
  font-weight: bold;
  color: #FFFFFF;
}

.action-secondary .action-title {
  color: var(--text-primary);
}

.action-desc {
  font-size: 12px;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.action-secondary .action-desc {
  color: var(--text-tertiary);
}

/* 区块标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: var(--text-primary);
}

.section-more {
  font-size: 12px;
  color: var(--text-tertiary);
}

/* 订单卡片 */
.order-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.order-card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.order-no {
  font-size: 12px;
  color: var(--text-tertiary);
}

.order-body {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.order-icon {
  width: 96rpx;
  height: 96rpx;
  background: #E6F7FF;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.order-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.order-type {
  font-size: 16px;
  font-weight: 500;
  color: var(--text-primary);
}

.order-city {
  font-size: 14px;
  color: var(--text-secondary);
}

.order-footer {
  border-top: 2rpx solid var(--border-color);
  padding-top: 16rpx;
}

.order-time {
  font-size: 12px;
  color: var(--text-tertiary);
}

/* 空状态 */
.empty-state {
  margin-top: 80rpx;
}

.empty-state .btn {
  width: 320rpx;
  margin-top: 32rpx;
}
