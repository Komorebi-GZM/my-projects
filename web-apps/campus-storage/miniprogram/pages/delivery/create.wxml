<!--pages/delivery/create.wxml-->
<view class="container">
  <!-- 订单信息卡片 -->
  <view class="card order-info-card">
    <view class="order-info-row">
      <text class="info-label">订单编号</text>
      <text class="info-value">{{order.orderNo}}</text>
    </view>
    <view class="order-info-row">
      <text class="info-label">物品类型</text>
      <text class="info-value">{{order.itemTypeText}}</text>
    </view>
    <view class="order-info-row">
      <text class="info-label">所在仓库</text>
      <text class="info-value">{{order.warehouseName || order.warehouseId}}</text>
    </view>
  </view>

  <!-- 配送地址 -->
  <view class="card">
    <view class="card-title">配送地址</view>
    <view class="form-list">
      <view class="form-item">
        <text class="form-label">联系人</text>
        <input 
          class="form-input" 
          placeholder="请输入联系人姓名" 
          value="{{deliveryInfo.contactName}}"
          bindinput="onInputChange"
          data-field="contactName"
        />
      </view>
      <view class="form-item">
        <text class="form-label">联系电话</text>
        <input 
          class="form-input" 
          type="number"
          placeholder="请输入联系电话" 
          value="{{deliveryInfo.contactPhone}}"
          bindinput="onInputChange"
          data-field="contactPhone"
        />
      </view>
      <view class="form-item address-item">
        <text class="form-label">详细地址</text>
        <textarea 
          class="form-textarea" 
          placeholder="请输入详细地址，如：XX大学XX宿舍楼X栋XXX室" 
          value="{{deliveryInfo.address}}"
          bindinput="onInputChange"
          data-field="address"
        />
      </view>
    </view>
  </view>

  <!-- 配送时间 -->
  <view class="card">
    <view class="card-title">配送时间</view>
    <view class="time-selector">
      <view 
        class="time-option {{deliveryInfo.deliveryTime === item.value ? 'active' : ''}}" 
        wx:for="{{timeOptions}}" 
        wx:key="value"
        bindtap="selectTime"
        data-value="{{item.value}}"
      >
        <text class="time-label">{{item.label}}</text>
        <text class="time-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 配送备注 -->
  <view class="card">
    <view class="card-title">配送备注（选填）</view>
    <textarea 
      class="remark-textarea" 
      placeholder="如有特殊要求请在此填写，如：请放在门卫室" 
      value="{{deliveryInfo.remark}}"
      bindinput="onInputChange"
      data-field="remark"
    />
  </view>

  <!-- 配送费用 -->
  <view class="card fee-card">
    <view class="card-title">配送费用</view>
    <view class="fee-display">
      <text class="fee-amount">¥{{deliveryFee}}</text>
      <text class="fee-desc">基础配送费，根据距离可能有所调整</text>
    </view>
  </view>

  <!-- 底部提交按钮 -->
  <view class="footer-bar">
    <view class="fee-summary">
      <text class="fee-label">配送费:</text>
      <text class="fee-value">¥{{deliveryFee}}</text>
    </view>
    <view class="btn btn-primary {{canSubmit ? '' : 'disabled'}}" bindtap="submitDelivery">
      {{canSubmit ? '确认发起配送' : '请完善信息'}}
    </view>
  </view>
</view>
