/**pages/delivery/create.wxss**/

/* 订单信息卡片 */
.order-info-card {
  background: linear-gradient(135deg, #1890FF, #096DD9);
  color: #FFFFFF;
}

.order-info-card .info-label {
  color: rgba(255, 255, 255, 0.8);
}

.order-info-card .info-value {
  color: #FFFFFF;
}

.order-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.2);
}

.order-info-row:last-child {
  border-bottom: none;
}

/* 表单列表 */
.form-list {
  display: flex;
  flex-direction: column;
}

.form-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 14px;
  color: var(--text-secondary);
  line-height: 48rpx;
}

.form-input {
  flex: 1;
  height: 48rpx;
  font-size: 14px;
  color: var(--text-primary);
  text-align: right;
}

.form-input::placeholder {
  color: var(--text-tertiary);
}

.address-item {
  flex-direction: column;
  gap: 16rpx;
}

.address-item .form-label {
  width: 100%;
}

.form-textarea {
  width: 100%;
  height: 120rpx;
  font-size: 14px;
  color: var(--text-primary);
  line-height: 1.6;
}

.form-textarea::placeholder {
  color: var(--text-tertiary);
}

/* 时间选择器 */
.time-selector {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.time-option {
  padding: 24rpx;
  border-radius: 12rpx;
  background: #F5F5F5;
  border: 2rpx solid transparent;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.time-option.active {
  background: #E6F7FF;
  border-color: var(--primary-color);
}

.time-label {
  font-size: 14px;
  color: var(--text-primary);
  font-weight: 500;
}

.time-option.active .time-label {
  color: var(--primary-color);
}

.time-desc {
  font-size: 12px;
  color: var(--text-tertiary);
}

/* 备注文本域 */
.remark-textarea {
  width: 100%;
  height: 160rpx;
  font-size: 14px;
  color: var(--text-primary);
  line-height: 1.6;
  padding: 16rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.remark-textarea::placeholder {
  color: var(--text-tertiary);
}

/* 费用卡片 */
.fee-card {
  margin-bottom: 160rpx;
}

.fee-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
}

.fee-amount {
  font-size: 48px;
  font-weight: bold;
  color: var(--primary-color);
}

.fee-desc {
  font-size: 12px;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

/* 底部栏 */
.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: var(--card-bg);
  border-top: 2rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.fee-summary {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.fee-summary .fee-label {
  font-size: 14px;
  color: var(--text-secondary);
}

.fee-summary .fee-value {
  font-size: 32px;
  font-weight: bold;
  color: var(--primary-color);
}

.footer-bar .btn {
  width: 320rpx;
  flex-shrink: 0;
}

.footer-bar .btn.disabled {
  background: #CCCCCC;
  color: #999999;
}
