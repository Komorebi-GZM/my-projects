/**app.wxss**/

/* 全局样式变量 */
page {
  --primary-color: #1890FF;
  --success-color: #52C41A;
  --warning-color: #FA8C16;
  --error-color: #F5222D;
  --disabled-color: #999999;
  --transit-color: #2396AB;
  --bg-color: #F5F5F5;
  --card-bg: #FFFFFF;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --border-color: #E8E8E8;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background-color: var(--bg-color);
  color: var(--text-primary);
  font-size: 14px;
  line-height: 1.5;
}

/* 容器 */
.container {
  padding: 32rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 16px;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: var(--text-primary);
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 8rpx;
  font-size: 16px;
  font-weight: 500;
  transition: all 0.2s;
}

.btn-primary {
  background: var(--primary-color);
  color: #FFFFFF;
}

.btn-primary:active {
  background: #096DD9;
  transform: scale(0.98);
}

.btn-primary[disabled] {
  background: #CCCCCC;
  color: #999999;
}

.btn-default {
  background: #FFFFFF;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

.btn-default:active {
  background: #E6F7FF;
}

/* 状态标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  font-size: 12px;
}

.tag-primary {
  background: #E6F7FF;
  color: var(--primary-color);
}

.tag-success {
  background: #F6FFED;
  color: var(--success-color);
}

.tag-warning {
  background: #FFF7E6;
  color: var(--warning-color);
}

.tag-error {
  background: #FFF1F0;
  color: var(--error-color);
}

.tag-disabled {
  background: #F5F5F5;
  color: var(--disabled-color);
}

.tag-transit {
  background: #E6FFFB;
  color: var(--transit-color);
}

/* 表单样式 */
.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 180rpx;
  color: var(--text-secondary);
  font-size: 14px;
}

.form-value {
  flex: 1;
  text-align: right;
  color: var(--text-primary);
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 14px;
}

.form-input::placeholder {
  color: var(--text-tertiary);
}

/* 列表样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--card-bg);
  border-bottom: 2rpx solid var(--border-color);
}

.list-item:last-child {
  border-bottom: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 14px;
  color: var(--text-tertiary);
  margin-bottom: 32rpx;
}

/* 底部固定按钮区 */
.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: var(--card-bg);
  border-top: 2rpx solid var(--border-color);
  display: flex;
  gap: 24rpx;
}

.footer-bar .btn {
  flex: 1;
}

/* 安全区域适配 */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: var(--border-color);
  margin: 24rpx 0;
}

/* 文本工具类 */
.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-tertiary {
  color: var(--text-tertiary);
}

.text-success {
  color: var(--success-color);
}

.text-warning {
  color: var(--warning-color);
}

.text-error {
  color: var(--error-color);
}

.font-bold {
  font-weight: bold;
}

/* 间距工具类 */
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mb-8 { margin-bottom: 8rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.ml-8 { margin-left: 8rpx; }
.ml-16 { margin-left: 16rpx; }
.mr-8 { margin-right: 8rpx; }
.mr-16 { margin-right: 16rpx; }

/* Flex工具类 */
.flex {
  display: flex;
}

.flex-1 {
  flex: 1;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}
