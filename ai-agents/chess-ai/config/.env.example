# ============================================
# 中国象棋AI对弈工具 - 环境变量模板
# ============================================
# 使用方法：
# 1. 复制本文件为 .env: cp .env.example .env
# 2. 编辑 .env 文件，填入你的实际配置值
# 3. 确保 .env 已加入 .gitignore，不要提交到版本控制

# ==================== LLM API 密钥配置 ====================
# 请根据你使用的模型提供商，配置对应的 API Key
# 未使用的提供商可以留空或删除

# DeepSeek API (推荐，性价比高)
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI API (GPT-4o)
# 获取地址: https://platform.openai.com/
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# 阿里云 DashScope (通义千问)
# 获取地址: https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# ==================== 本地模型配置 ====================
# Ollama 本地部署（无需联网，无需 API Key）
# 安装地址: https://ollama.com/
OLLAMA_BASE_URL=http://localhost:11434

# ==================== LangSmith 可观测性配置（可选） ====================
# 用于追踪 LLM 调用、调试和优化
# 获取地址: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls-your-langsmith-api-key-here
LANGCHAIN_PROJECT=chess-ai-llm

# ==================== 应用配置覆盖 ====================
# 以下配置会覆盖 config.yaml 中的对应值

# 日志级别
# CHESS_LOG_LEVEL=DEBUG

# 数据库路径
# CHESS_DB_PATH=./data/chess.db

# 检查点数据库路径
# CHESS_CHECKPOINT_PATH=./data/checkpoints.db

# 最大重试次数
# CHESS_MAX_RETRIES=3

# LLM 超时时间（秒）
# CHESS_LLM_TIMEOUT=15
