# ============================================
# 中国象棋AI对弈工具 - Git 忽略规则
# ============================================

# ==================== Python ====================
# 字节码
__pycache__/
*.py[cod]
*$py.class
*.so

# 分发/打包
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# 虚拟环境
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# ==================== IDE ====================
# PyCharm
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/
*.code-workspace
.history/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ==================== 配置文件（敏感信息） ====================
# 环境变量（包含 API Key）
config/.env
.env
.env.local
.env.*.local

# 本地配置文件（可能包含敏感信息）
config/config.local.yaml
config/*.local.yaml

# ==================== 数据文件 ====================
# 数据库文件
*.db
*.sqlite
*.sqlite3
data/

# 检查点文件
checkpoints/
*.checkpoint

# 日志文件
logs/
*.log
log/

# 对局记录
saves/
*.pgn
*.fen

# ==================== 资源文件（可选忽略） ====================
# 如果需要版本控制资源文件，请注释以下行
# assets/images/pieces/*.png
# assets/sounds/*.wav

# ==================== 测试相关 ====================
# 测试覆盖率
htmlcov/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.codegraph/

# ==================== 操作系统 ====================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# Linux
*~
.nfs*

# ==================== 其他 ====================
# 临时文件
*.tmp
*.temp
*.swp
*.swo
*~

# 备份文件
*.bak
*.backup

# 下载的参考资料（大文件）
docs/references/*.pdf
docs/references/*.html

# 打包输出
*.spec
